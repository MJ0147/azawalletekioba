# ─────────────────────────────────────────────────────────────────
# EKIOBA — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# Generate a secret key with: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL connection URL for the Store and Hotels services
STORE_URL=postgresql://user:password@host:5432/ekioba_store?sslmode=require
HOTELS_URL=postgresql://user:password@host:5432/ekioba_hotels?sslmode=require

# ── Django ────────────────────────────────────────────────────────
# Minimum 50 characters. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
DJANGO_SECRET_KEY=change-me-use-at-least-50-random-characters

# Set to "True" only during local development
DEBUG=False

# Comma-separated list of allowed hostnames in production
ALLOWED_HOSTS=ekioba.com,www.ekioba.com

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-use-at-least-50-random-characters

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://ekioba.com,https://www.ekioba.com

# ── Docker Compose service URLs ───────────────────────────────────
STORE_BACKEND_URL=http://store:8001/api/products/
STORE_PAYMENTS_URL=http://store:8001/payments/process/
AI_ASSISTANT_URL=http://ai_assistant:8005
FRONTEND_IYOBO_URL=/chat

# ── TON Blockchain ────────────────────────────────────────────────
TONPAY_API_KEY=your-tonpay-api-key
TON_API_KEY=your-ton-api-key
TON_MERCHANT_WALLET=your-ton-wallet-address
TON_CONTRACT_ADDRESS=your-ton-contract-address

# ── Solana Blockchain ─────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_API_KEY=your-solana-api-key
SOLANA_MERCHANT_WALLET=your-solana-wallet-address

# ── External APIs ─────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
COPILOT_API_KEY=your-copilot-or-openai-api-key
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
GOOGLE_GENAI_API_KEY=your-google-genai-api-key
