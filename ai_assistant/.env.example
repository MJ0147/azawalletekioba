# ─────────────────────────────────────────────────────────────────
# AI Assistant — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────
# Full connection URI — PostgreSQL, MySQL, or Redis (rediss://) supported
DATABASE_URL=postgresql://user:password@host:5432/ekioba_ai?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────
# Must be at least 32 characters.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-secret-key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── App ───────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME="Iyobo AI Assistant"

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://ekioba.com,http://localhost:3000

# ── AI / Copilot ─────────────────────────────────────────────────
COPILOT_API_KEY=your-copilot-or-openai-api-key
COPILOT_BASE_URL=https://models.inference.ai.azure.com
COPILOT_MODEL=gpt-4o-mini

# ── Google AI ─────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GOOGLE_GENAI_API_KEY=your-google-genai-api-key

# ── Telegram ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ── TON Blockchain ────────────────────────────────────────────────
TONPAY_API_KEY=your-tonpay-api-key
TON_CONTRACT_ADDRESS=your-ton-contract-address

# ── Connection Pool Tuning (optional) ─────────────────────────────
# Only applies when DATABASE_URL is a relational DB (PostgreSQL/MySQL)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
